# Custom Dockerfile for E-Traders n8n
# Extends n8n with custom nodes for trading AI

FROM n8nio/n8n:1.65.0

# Install additional packages
USER root
RUN npm install -g @n8n/n8n-nodes-langchain@1.41.0

# Create custom nodes directory
RUN mkdir -p /home/node/.n8n/custom

# Copy custom nodes (if any)
COPY ./custom-nodes /home/node/.n8n/custom

# Set permissions
RUN chown -R node:node /home/node/.n8n

USER node

CMD ["n8n start"]