# E-Traders Environment Configuration
# Copy this file to .env and customize values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DB_PASSWORD=etraders_secure_password_2024
DB_HOST=localhost
DB_PORT=5432

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ===========================================
# PORTS
# ===========================================
NEXTJS_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379

# ===========================================
# OLLAMA CONFIGURATION (IA)
# ===========================================
# Sur votre machine locale, Ollama doit être lancé
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=ollama

# Modèle par défaut
DEFAULT_OLLAMA_MODEL=llama3.2

# ===========================================
# TRADING API KEYS (Optionnel)
# ===========================================
# BINANCE_API_KEY=your_binance_key
# BINANCE_SECRET=your_binance_secret
# METATRADER_ACCOUNT=your_mt5_account
# METATRADER_PASSWORD=your_mt5_password

# ===========================================
# SÉCURITÉ
# ===========================================
JWT_SECRET=etraders_jwt_secret_2024_change_me
ENCRYPTION_KEY=etraders_encryption_key_2024_change_me

# ===========================================
# EMAIL NOTIFICATIONS (Optionnel)
# ===========================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ===========================================
# URL DE L'APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000